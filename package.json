{
  "name": "rvn-socketio-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "oxlint",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "type:check": "tsc --noEmit"
  },
  "dependencies": {
    "@rvncom/socketio-bun-engine": "^1.1.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.2"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  },
  "license": "MIT"
}
