# WebSocket Server
PORT=3002
NODE_ENV=development
MAX_CLIENTS=0

# rvn-web internal API
# In production (Docker), use the internal service name.
# Example: http://localhost:3001
AUTH_SERVICE_URL=http://localhost:3001
INTERNAL_API_KEY=generate-a-shared-secret

# CORS Origins (comma-separated)
# In production, use the public domain of your web application (https).
# Example: https://domain.com,https://www.domain.com
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
